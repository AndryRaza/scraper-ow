<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/bo.css">
</head>
<body>
  <header>
    <h1><%= title %></h1>
    <span class="count"><%= tweets.length %> affichés / <%= totalTweets %> total</span>
    <div class="selection-actions">
      <button id="selectAllBtn" class="btn btn-outline">Tout s&eacute;lectionner</button>
      <button id="deselectAllBtn" class="btn btn-outline" disabled>Annuler les s&eacute;lections</button>
    </div>
    <button id="scrapeBtn" class="btn btn-primary">Scraper maintenant</button>
    <button id="deleteBtn" class="btn btn-danger" disabled>Supprimer la s&eacute;lection</button>
  </header>

  <section class="accounts-section">
    <h2>Comptes surveill&eacute;s</h2>
    <div class="accounts-list">
      <% accounts.forEach(function(acc) { %>
        <span class="account-tag" data-account="<%= acc.handle %>">
          <label class="toggle-switch">
            <input type="checkbox" class="toggle-check" data-account="<%= acc.handle %>" <%= acc.enabled ? 'checked' : '' %>>
            <span class="toggle-slider"></span>
          </label>
          @<%= acc.handle %>
          <button class="remove-account-btn" data-account="<%= acc.handle %>" title="Supprimer définitivement">&times;</button>
        </span>
      <% }); %>
    </div>
    <form id="addAccountForm" class="add-account-form">
      <input type="text" id="addAccountInput" placeholder="@elonmusk" required>
      <button type="submit" class="btn btn-primary btn-sm">Ajouter</button>
    </form>
  </section>

  <main>
    <% if (tweets.length === 0) { %>
      <div class="empty">Aucun tweet pour le moment. Lance un scraping d'abord.</div>
    <% } else { %>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>
                <a href="?sortBy=account&sortOrder=<%= sortBy === 'account' ? nextOrder : 'asc' %>&page=1&perPage=<%= perPage %>" class="sort-header">
                  Compte
                  <% if (sortBy === 'account') { %>
                    <svg class="sort-arrow active" width="10" height="10" viewBox="0 0 10 10">
                      <% if (sortOrder === 'asc') { %>
                        <path d="M5 0L10 8H0z" fill="#2b66d9"/>
                      <% } else { %>
                        <path d="M0 2L5 10L10 2z" fill="#2b66d9"/>
                      <% } %>
                    </svg>
                  <% } else { %>
                    <svg class="sort-arrow" width="10" height="10" viewBox="0 0 10 10">
                      <path d="M5 0L10 8H0z" fill="#ccc"/>
                    </svg>
                  <% } %>
                </a>
              </th>
              <th>Texte</th>
              <th>
                <a href="?sortBy=date&sortOrder=<%= sortBy === 'date' ? nextOrder : 'desc' %>&page=1&perPage=<%= perPage %>" class="sort-header">
                  Date
                  <% if (sortBy === 'date') { %>
                    <svg class="sort-arrow active" width="10" height="10" viewBox="0 0 10 10">
                      <% if (sortOrder === 'asc') { %>
                        <path d="M5 0L10 8H0z" fill="#2b66d9"/>
                      <% } else { %>
                        <path d="M0 2L5 10L10 2z" fill="#2b66d9"/>
                      <% } %>
                    </svg>
                  <% } else { %>
                    <svg class="sort-arrow" width="10" height="10" viewBox="0 0 10 10">
                      <path d="M0 2L5 10L10 2z" fill="#ccc"/>
                    </svg>
                  <% } %>
                </a>
              </th>
              <th>Liens</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% tweets.forEach(function(t) { %>
              <tr>
                <td class="account">@<%= t.account %></td>
                <td class="text"><%= t.text || '' %></td>
                <td class="date"><%= t.date ? new Date(t.date).toLocaleString('fr-FR') : '-' %></td>
                <td class="links">
                  <% if (t.links && t.links.length > 0) { %>
                    <a href="<%= t.links[0] %>" target="_blank" class="btn-link">Voir</a>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td><input type="checkbox" class="tweet-check" data-id="<%= t.id %>" /></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div class="pagination">
        <% if (currentPage > 1) { %>
          <a href="?sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>&page=<%= currentPage - 1 %>&perPage=<%= perPage %>" class="btn btn-outline">Pr&eacute;c&eacute;dent</a>
        <% } else { %>
          <span class="btn btn-outline" disabled>Pr&eacute;c&eacute;dent</span>
        <% } %>

        <% for (var p = 1; p <= totalPages; p++) { %>
          <% if (p === currentPage) { %>
            <span class="page-num active"><%= p %></span>
          <% } else { %>
            <a href="?sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>&page=<%= p %>&perPage=<%= perPage %>" class="page-num"><%= p %></a>
          <% } %>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <a href="?sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>&page=<%= currentPage + 1 %>&perPage=<%= perPage %>" class="btn btn-outline">Suivant</a>
        <% } else { %>
          <span class="btn btn-outline" disabled>Suivant</span>
        <% } %>
      </div>
    <% } %>
  </main>

  <div id="scrapeOverlay" class="scrape-overlay" style="display:none;">
    <div class="scrape-dialog">
      <div class="spinner"></div>
      <p class="scrape-title">Scraping en cours...</p>
      <p class="scrape-sub">Un navigateur Chromium va s'ouvrir pour récolter les tweets. Ne ferme rien.</p>
      <button id="cancelScrapeBtn" class="btn btn-danger" style="margin-top:24px;">Annuler</button>
    </div>
  </div>

  <style>
    .scrape-overlay {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,0.25);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }

    .scrape-dialog {
      background: #fff;
      border-radius: 12px;
      padding: 40px 50px;
      text-align: center;
      box-shadow: 0 8px 40px rgba(0,0,0,0.15);
      max-width: 400px;
    }

    .scrape-title {
      font-size: 18px;
      font-weight: 600;
      margin-top: 20px;
    }

    .scrape-sub {
      font-size: 13px;
      color: #888;
      margin-top: 8px;
    }

    .spinner {
      width: 40px;
      height: 40px;
      margin: 0 auto;
      border: 4px solid #e0e3eb;
      border-top-color: #2b66d9;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .accounts-section {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      padding: 16px 20px;
      margin-bottom: 20px;
    }

    .accounts-section h2 {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 10px;
      color: #555;
    }

    .accounts-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
    }

    .account-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #e8ebf0;
      padding: 4px 12px;
      border-radius: 16px;
      font-size: 13px;
      font-weight: 500;
    }

    .remove-account-btn {
      background: none;
      border: none;
      color: #999;
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
      padding: 0;
    }

    .remove-account-btn:hover {
      color: #e74c3c;
    }

    .add-account-form {
      display: flex;
      gap: 8px;
    }

    .add-account-form input {
      flex: 1;
      max-width: 240px;
      padding: 6px 12px;
      border: 1px solid #c0c5d0;
      border-radius: 6px;
      font-size: 13px;
    }

    .btn-sm {
      padding: 6px 14px;
      font-size: 13px;
    }

    .toggle-switch {
      position: relative;
      display: inline-block;
      width: 32px;
      height: 18px;
      flex-shrink: 0;
    }

    .toggle-switch .toggle-check {
      opacity: 0;
      width: 0;
      height: 0;
      position: absolute;
    }

    .toggle-slider {
      position: absolute;
      cursor: pointer;
      inset: 0;
      background: #c0c5d0;
      border-radius: 18px;
      transition: background 0.2s;
    }

    .toggle-slider::before {
      content: '';
      position: absolute;
      left: 2px;
      top: 2px;
      width: 14px;
      height: 14px;
      background: #fff;
      border-radius: 50%;
      transition: transform 0.2s;
    }

    .toggle-check:checked + .toggle-slider {
      background: #2b66d9;
    }

    .toggle-check:checked + .toggle-slider::before {
      transform: translateX(14px);
    }

    .account-tag.disabled {
      opacity: 0.5;
    }
  </style>

  <script>
    var checkboxes = document.querySelectorAll('.tweet-check');
    var selectAllBtn = document.getElementById('selectAllBtn');
    var deselectAllBtn = document.getElementById('deselectAllBtn');
    var deleteBtn = document.getElementById('deleteBtn');
    var scrapeBtn = document.getElementById('scrapeBtn');
    var scrapeOverlay = document.getElementById('scrapeOverlay');

    function updateButtons() {
      var total = checkboxes.length;
      var checked = document.querySelectorAll('.tweet-check:checked').length;

      deleteBtn.disabled = checked === 0;
      deleteBtn.textContent = 'Supprimer la s\u00e9lection' + (checked > 0 ? ' (' + checked + ')' : '');

      selectAllBtn.disabled = checked === total;
      deselectAllBtn.disabled = checked === 0;
    }

    checkboxes.forEach(function(cb) {
      cb.addEventListener('change', updateButtons);
    });

    selectAllBtn.addEventListener('click', function() {
      checkboxes.forEach(function(cb) { cb.checked = true; });
      updateButtons();
    });

    deselectAllBtn.addEventListener('click', function() {
      checkboxes.forEach(function(cb) { cb.checked = false; });
      updateButtons();
    });

    deleteBtn.addEventListener('click', function() {
      var checked = document.querySelectorAll('.tweet-check:checked');
      var ids = Array.from(checked).map(function(cb) { return cb.getAttribute('data-id'); });

      if (ids.length === 0) return;

      fetch('/bo/api/tweets/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: ids })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          location.reload();
        } else {
          alert('Erreur : ' + data.error);
        }
      })
      .catch(function(err) {
        alert('Erreur r\u00e9seau : ' + err.message);
      });
    });

    var cancelScrapeBtn = document.getElementById('cancelScrapeBtn');

    scrapeBtn.addEventListener('click', function() {
      scrapeOverlay.style.display = 'flex';
      cancelScrapeBtn.disabled = false;

      fetch('/api/scrape', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ maxTweets: 50 })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        location.reload();
      })
      .catch(function(err) {
        alert('Erreur lors du scraping : ' + err.message);
        scrapeOverlay.style.display = 'none';
      });
    });

    cancelScrapeBtn.addEventListener('click', function() {
      this.disabled = true;
      this.textContent = 'Annulation...';

      fetch('/api/scrape/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        // La requête de scraping va recevoir cancelled: true et relancer la page
      })
      .catch(function(err) {
        cancelScrapeBtn.disabled = false;
        cancelScrapeBtn.textContent = 'Annuler';
      });
    });

    /* Gestion des comptes */
    const addAccountForm = document.getElementById('addAccountForm');
    const addAccountInput = document.getElementById('addAccountInput');

    addAccountForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var account = addAccountInput.value.trim();

      fetch('/api/accounts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ account: account })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          addAccountInput.value = '';
          location.reload();
        } else {
          alert('Erreur : ' + data.error);
        }
      })
      .catch(function(err) {
        alert('Erreur réseau : ' + err.message);
      });
    });

    /* Toggle enable/disable */
    document.querySelectorAll('.toggle-check').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var account = this.getAttribute('data-account');
        var enabled = this.checked;

        fetch('/api/accounts/' + encodeURIComponent(account), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ enabled: enabled })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.success) {
            alert('Erreur : ' + data.error);
          }
          location.reload();
        })
        .catch(function(err) {
          alert('Erreur réseau : ' + err.message);
          location.reload();
        });
      });
    });

    /* Suppression définitive */
    document.querySelectorAll('.remove-account-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (!confirm('Supprimer définitivement ce compte ?')) return;
        var account = this.getAttribute('data-account');

        fetch('/api/accounts/' + encodeURIComponent(account), {
          method: 'DELETE'
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            location.reload();
          } else {
            alert('Erreur : ' + data.error);
          }
        })
        .catch(function(err) {
          alert('Erreur réseau : ' + err.message);
        });
      });
    });

    /* Ajout du style disabled sur les comptes inactifs */
    document.querySelectorAll('.toggle-check').forEach(function(cb) {
      var tag = cb.closest('.account-tag');
      if (tag) {
        if (!cb.checked) tag.classList.add('disabled');
        cb.addEventListener('change', function() {
          tag.classList.toggle('disabled', !this.checked);
        });
      }
    });
  </script>
</body>
</html>
